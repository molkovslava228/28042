# Игнорировать все файлы .pyc и папки __pycache__ (компилированные файлы Python)
*.pyc
__pycache__/

# Игнорировать файл базы данных, если используете (например, SQLite)
*.sqlite3

# Игнорировать файлы настроек IDE, например, для PyCharm или VSCode
.idea/
.vscode/

# Игнорировать временные файлы и резервные копии
*~
*.bak

# Игнорировать файл, если сохраняете большие данные или секреты
# (например, файлы с данными или ключи)
secret_key.txt
